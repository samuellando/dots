#!/bin/sh

battery=$(cat /sys/class/power_supply/BAT0/capacity | awk '{printf "%d\n", $1}')
batteryStatus=$(cat /sys/class/power_supply/BAT0/status)
datetime=$(date +'%Y-%m-%d %X')
memory=$(free | awk '/Mem/ {printf "%02.0f\n", $3/$2 * 100.0}')
cpu=$(grep 'cpu ' /proc/stat | awk '{usage=($2+$4)*100/($2+$4+$5)} END {printf "%02.0f\n", usage}')
wifi=$(iwctl station wlan0 show | awk -F 'Connected network *' '/Connected network/ {print $2}' | awk '{$1=$1;print}')
volume=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | awk '{printf "%02.0f\n", $2 * 100.0}')
muted=$(wpctl get-volume @DEFAULT_AUDIO_SINK@ 2>/dev/null | awk '{printf $3}')


if [ "$battery" -lt 15 ]  && [[ "$batteryStatus" == "Discharging" ]]; then
     if [ $(( $(date +%s) % 2 )) -eq 0 ]; then
         swaymsg bar 0 colors background "#ea6962"
     else
         swaymsg bar 0 colors background "#282828"
     fi
 else
         swaymsg bar 0 colors background "#282828"
fi

if [ $muted == "[MUTED]" ]; then
    volume="*$volume"
fi

echo "C: $cpu% . M: $memory% . B: $battery% (${batteryStatus:0:1}) . V: $volume% . $wifi . $datetime "
